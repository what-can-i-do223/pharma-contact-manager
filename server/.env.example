# Copy to `.env` and adjust if your Postgres differs from the defaults.
# With a stock Homebrew/local Postgres (same OS user, no password, port 5432)
# the defaults below work as-is and you don't even need a .env file.

# Standard libpq-style connection string used by src/db.js.
DATABASE_URL=postgres://localhost:5432/pharma_contacts

# Port the Express API listens on. The Vite dev server (Phase 4) proxies
# /api requests here.
PORT=3001
