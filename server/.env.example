# ============================================================================
# Copy this file to server/.env and fill in real values. server/.env is
# gitignored — real credentials must NEVER be committed (only this example
# file, with placeholders, is tracked).
# ============================================================================

# --- Database ---------------------------------------------------------------
# Standard libpq-style connection string used by src/db.js. With a stock
# Homebrew/local Postgres (same OS user, no password, port 5432) this default
# works as-is.
DATABASE_URL=postgres://localhost:5432/pharma_contacts

# --- Server -------------------------------------------------------------------
# Port the Express API listens on. The Vite dev server proxies /api and /auth
# requests here.
PORT=3001

# Where to send the browser after a successful Google login — the client
# app's origin. Default fits `npm run dev:client`.
APP_ORIGIN=http://localhost:5173

# --- Sessions (Phase 7) -------------------------------------------------------
# Signs the app's session JWT cookie, and (hashed) becomes the encryption key
# for stored Google refresh tokens. Generate a strong random value with:
#   openssl rand -hex 32
# Changing it logs every rep out and orphans stored refresh tokens (reps just
# sign in with Google again).
SESSION_SECRET=generate-with-openssl-rand-hex-32

# --- Google OAuth (Phase 7+) ---------------------------------------------------
# Create your OWN credentials at https://console.cloud.google.com/ :
#   1. Create a project (any name).
#   2. APIs & Services → Library: enable "Google Calendar API" and "Gmail API".
#   3. APIs & Services → OAuth consent screen: External, add yourself as a
#      test user (the app can stay in "Testing" — no verification needed).
#   4. APIs & Services → Credentials → Create credentials → OAuth client ID →
#      Web application. Add the EXACT redirect URI below to
#      "Authorized redirect URIs".
#   5. Copy the client ID and secret here.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# --- Daily digest scheduler (Phase 9 follow-up) -------------------------------
# OFF BY DEFAULT — commented out on purpose. Uncommenting this is what turns
# the scheduler ON; leaving it unset (the default for a fresh checkout / local
# dev) means no digest email ever fires on its own. The in-app "Send me
# today's tasks" button always works regardless of this setting.
#
# Only meaningful on an ALWAYS-ON host (a VM, a container kept alive by a
# process manager). node-cron is an in-process timer: if this server isn't
# running at 7am, that day's job simply doesn't happen — it is not a system
# cron job and does not queue up missed runs. See server/src/scheduler.js.
#
# Standard 5-field cron syntax: minute hour day month weekday.
# DIGEST_CRON=0 7 * * *

# Force the scheduler off even if DIGEST_CRON above is set — e.g. if you're
# running more than one instance of this server and only want one of them
# sending digests.
# DISABLE_SCHEDULER=true
